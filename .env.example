# =============================================================
# AutoOps — 启动配置
# 复制为 .env 并按需填写，其余全部可选。
# =============================================================

# 数据库密码（必填，仅使用内置 PostgreSQL 时需要）
POSTGRES_PASSWORD=your_db_password_here

# =============================================================
# 以下均为可选，留空或删除即可使用默认值 / 在页面里设置。
# =============================================================

# 登录密码（可选）
# 留空或不填：首次访问浏览器会自动跳到初始化设置页面，在那里设置密码。
# 填入后：服务启动时自动将此密码写入数据库，直接跳到登录页输入此密码。
# 首次设置后可在 Settings 页面修改，修改后这里可以删掉。
#DASHBOARD_PASSWORD=

# 外部 PostgreSQL（不用内置数据库时填）
# 配合 docker-compose.external-db.yml 使用，见 README。
#DATABASE_URL=postgresql://user:password@host:5432/dbname

# 主机端口（默认 80）
#PORT=80

# 加密密钥（自动生成，勿轻易修改）
# 仅在迁移服务器恢复备份时需要手动填。
# 警告：修改后已保存的所有账号密码将无法解密。
#ENCRYPTION_KEY=
#SESSION_SECRET=

# 日志级别（默认 info）
# 可选值: trace | debug | info | warn | error | fatal
#LOG_LEVEL=info

# Session Cookie 安全标志（默认 false）
# 仅在 HTTPS 反向代理后面运行时设为 true，否则浏览器不会发送 cookie。
# 本地 HTTP 访问时保持 false（默认）。
#SECURE_COOKIES=false

# =============================================================
# 以下配置请在启动后通过页面 Settings 修改，无需在此设置：
#   - 浏览器连接（Browser Connection）：WebSocket 地址、连接协议
#   - 验证码服务（Captcha）：服务商、API Key
#   - CORS 允许来源（高级）
# =============================================================
