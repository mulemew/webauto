# =============================================================
# AutoOps — 启动配置
# 复制为 .env 并按需填写，其余全部可选。
# =============================================================

# 数据库密码（必填，仅使用内置 PostgreSQL 时需要）
POSTGRES_PASSWORD=your_db_password_here

# =============================================================
# 以下均为可选，留空或删除即可使用默认值 / 在页面里设置。
# =============================================================

# 登录密码（可选）
# 留空或不填：首次访问浏览器会自动跳到初始化设置页面，在那里设置密码。
# 填入后：服务启动时自动将此密码写入数据库，直接跳到登录页输入此密码。
# 首次设置后可在 Settings 页面修改，修改后这里可以删掉。
#DASHBOARD_PASSWORD=

# 外部 PostgreSQL（不用内置数据库时填）
# 配合 docker-compose.external-db.yml 使用，见 README。
#DATABASE_URL=postgresql://user:password@host:5432/dbname

# 主机端口（默认 80）
#PORT=80

# 加密密钥（自动生成，勿轻易修改）
# 仅在迁移服务器恢复备份时需要手动填。
# 警告：修改后已保存的所有账号密码将无法解密。
#ENCRYPTION_KEY=
#SESSION_SECRET=

# 日志级别（默认 info）
# 可选值: trace | debug | info | warn | error | fatal
#LOG_LEVEL=info

# Session Cookie 安全标志（默认 false）
# 仅在 HTTPS 反向代理后面运行时设为 true，否则浏览器不会发送 cookie。
# 本地 HTTP 访问时保持 false（默认）。
#SECURE_COOKIES=false

# reCAPTCHA 音频验证自动破解（可选，默认已能用本地 Whisper）
# 目标站出现 Google reCAPTCHA 时，系统会自动走"音频挑战"破解：
# 下载语音 → 转文字 → 填答案。转文字引擎按下面顺序回退：
#   whisper = cf-proxy 容器内本地 faster-whisper（免费、无需 key、离线，默认首选）
#   witai   = wit.ai 免费语音 API（需下面的 token，稳定/快，作为加速/备用）
#   google  = 免费 Google 端点（无需 key 但不稳定，垫底）
#RECAPTCHA_STT_ORDER=whisper,witai,google
# 本地 Whisper 模型大小（cf-proxy）：tiny|base|small|medium，越大越准越慢，默认 small
#WHISPER_MODEL=small
# wit.ai token（用了 witai 引擎才需要，https://wit.ai 免费注册后拿 Server Access Token）
#WIT_AI_TOKEN=

# 浏览器指纹伪装（cf-proxy，默认关闭）
# 把 ARM Linux 的"一眼自动化"指纹伪装成 Windows/Mac：UA + UA-CH 客户端提示 +
# navigator.platform + WebGL 厂商串 + 时区/语言。Windows 伪装度更高（有免费
# 度量兼容字体），Mac 的标志性字体无法伪装。
# ⚠️ 半吊子伪装可能反而让 Cloudflare Turnstile 更难过——开启后请实测对比，
#    CF 站点若变差就关掉。默认关。
#FINGERPRINT_OS=windows            # windows | mac | 留空=关
# 时区/语言：不填则按会话出口 IP 自动检测（走该会话代理查 ip-api）；填了就用你填的
#FINGERPRINT_TZ=America/New_York
#FINGERPRINT_LOCALE=en-US
#FINGERPRINT_AUTOGEO=1             # 1=按出口IP自动对齐时区/语言（默认），0=关自动

# =============================================================
# 以下配置请在启动后通过页面 Settings 修改，无需在此设置：
#   - 浏览器连接（Browser Connection）：WebSocket 地址、连接协议
#   - 验证码服务（Captcha）：服务商、API Key
#   - CORS 允许来源（高级）
# =============================================================
