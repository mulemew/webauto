# Version control
.git
.gitignore

# Dependencies — reinstalled during Docker build
node_modules
**/node_modules

# Build outputs — rebuilt during Docker build
dist
**/dist
*.tsbuildinfo

# Replit-specific — not needed in Docker
.replit
.replitignore
.local/
.cache/
.agents/

# Environment files — never bake secrets into images
.env
.env.local
.env.*.local

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Attached assets (large files not needed in the build)
attached_assets/

# Test / coverage
coverage/
